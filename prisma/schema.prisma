generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      UserRole @default(ADMIN)
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  branch    Branch?  @relation(fields: [branchId], references: [id])

  @@index([email])
  @@index([role])
}

model Branch {
  id                String          @id @default(cuid())
  name              String
  address           String
  city              String
  state             String
  phone             String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt
  inventories       Inventory[]
  sales             Sale[]
  outgoingTransfers StockTransfer[] @relation("FromBranch")
  incomingTransfers StockTransfer[] @relation("ToBranch")
  users             User[]

  @@index([name])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  products  Product[]
}

model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  categoryId      String
  collectionId    String?
  size            String?
  thickness       String?
  finish          String?
  texture         String?
  material        String?
  pricePerBox     Float
  coverImage      String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  piecesPerBox    Int?
  pricePerPiece   Float?
  pricePerSqft    Float?
  pricePerSqm     Float?
  sku             String?         @unique
  lowStockAlert   Int             @default(50)
  reservedStock   Int             @default(0)
  stockQty        Int             @default(0)
  dealerCartItems DealerCart[]
  inquiries       Inquiry[]
  inventories     Inventory[]
  category        Category        @relation(fields: [categoryId], references: [id])
  collection      Collection?     @relation(fields: [collectionId], references: [id])
  productImages   ProductImage[]
  saleItems       SaleItem[]
  stockTransfers  StockTransfer[]
  wishlists       Wishlist[]
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Inventory {
  id            String   @id @default(cuid())
  branchId      String
  productId     String
  boxes         Int      @default(0)
  pieces        Int      @default(0)
  reservedBoxes Int      @default(0)
  damagedBoxes  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  branch        Branch   @relation(fields: [branchId], references: [id])
  product       Product  @relation(fields: [productId], references: [id])

  @@unique([branchId, productId])
  @@index([branchId])
  @@index([productId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  sales     Sale[]

  @@index([name])
  @@index([phone])
}

model Sale {
  id            String     @id @default(cuid())
  invoiceNumber String     @unique
  branchId      String
  customerId    String
  totalAmount   Float
  gstAmount     Float
  status        String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt
  branch        Branch     @relation(fields: [branchId], references: [id])
  customer      Customer   @relation(fields: [customerId], references: [id])
  items         SaleItem[]

  @@index([invoiceNumber])
  @@index([branchId])
  @@index([customerId])
}

model SaleItem {
  id             String   @id @default(cuid())
  saleId         String
  productId      String
  quantityBoxes  Int
  quantityPieces Int
  price          Float
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id])
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model StockTransfer {
  id           String   @id @default(cuid())
  fromBranchId String
  toBranchId   String
  productId    String
  boxes        Int
  pieces       Int      @default(0)
  status       String   @default("PENDING")
  notes        String?
  createdAt    DateTime @default(now())
  fromBranch   Branch   @relation("FromBranch", fields: [fromBranchId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
  toBranch     Branch   @relation("ToBranch", fields: [toBranchId], references: [id])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  dealerId      String
  subtotal      Float
  gstAmount     Float
  totalAmount   Float
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
}

model DealerCart {
  id        String   @id @default(cuid())
  dealerId  String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Dealer {
  id              String        @id @default(cuid())
  businessName    String
  ownerName       String
  email           String        @unique
  phone           String
  password        String
  address         String?
  gstNumber       String?
  creditLimit     Float         @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  availableCredit Float         @default(0)
  totalOrders     Float         @default(0)
  orders          DealerOrder[]
}

model DealerOrder {
  id          String   @id @default(cuid())
  dealerId    String
  orderNumber String   @unique
  totalAmount Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  dealer      Dealer   @relation(fields: [dealerId], references: [id])
}

model Collection {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  coverImage  String?
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  location    String?
  year        String?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String?
  image     String
  category  String?
  createdAt DateTime @default(now())
}

model HomepageSection {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String?
  subtitle    String?
  description String?
  image       String?
  buttonText  String?
  buttonLink  String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Inquiry {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  company   String?
  message   String?
  productId String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  product   Product? @relation(fields: [productId], references: [id])
}

model Wishlist {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model CatalogDownload {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  company   String?
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  STAFF
}
